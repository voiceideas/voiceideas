+
+    private func resolveDurationMilliseconds(from recorder: AVAudioRecorder) -> Double {
+        let recorderDuration = recorder.currentTime * 1000
+        if recorderDuration > 0 {
+            return recorderDuration
+        }
+
+        guard let recordingStartDate else {
+            return 0
+        }
+
+        let effectiveEndDate: Date
+        if status == .paused, let pauseStartDate {
+            effectiveEndDate = pauseStartDate
+        } else {
+            effectiveEndDate = Date()
+        }
+
+        let duration = effectiveEndDate.timeIntervalSince(recordingStartDate) - accumulatedPauseDuration
+        return max(duration * 1000, 0)
+    }
+
+    private func resolveFileSize(for url: URL) -> UInt64? {
