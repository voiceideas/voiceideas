+        let fileSize = currentFileURL.flatMap(resolveFileSize) ?? 0
+
+        CAPLog.print(
+            "CapacitorAudioRecorderPlugin",
+            "recording finished at \(currentFileURL?.path ?? "<unknown>") size=\(fileSize) durationMs=\(durationMilliseconds)"
