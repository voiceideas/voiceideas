{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VoiceIdeas",
  "version": "0.1.0",
  "identifier": "com.voiceideas.desktop",
  "build": {
    "frontendDist": "../desktop-dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:native-web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoiceIdeas",
        "width": 1280,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720,
        "useHttpsScheme": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "infoPlist": "Info.plist"
    }
  }
}
